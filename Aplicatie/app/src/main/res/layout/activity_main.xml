<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <WebView
        android:id="@+id/cameraView"
        android:layout_width="320dp"
        android:layout_height="240dp"
        android:layout_margin="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/dpadLayout"
        app:layout_constraintEnd_toStartOf="@id/dpadCameraLayout"
        android:visibility="invisible"
        />
    <Button
        android:id="@+id/btnStartStream"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/start_stream"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <Button
        android:id="@+id/btnStopStream"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/stop_stream"
        android:layout_margin="16dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />
    <GridLayout
        android:id="@+id/dpadLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:columnCount="3"
        android:rowCount="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent">


        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

        <ImageButton
            android:id="@+id/btnForward"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/round_button"
            android:rotation="90"
            android:src="@drawable/arrow"
            tools:ignore="ContentDescription" />

        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

        <ImageButton
            android:id="@+id/btnLeft"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/round_button"
            android:src="@drawable/arrow"
            tools:ignore="ContentDescription"/>

        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

        <ImageButton
            android:id="@+id/btnRight"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/round_button"
            android:rotation="180"
            android:src="@drawable/arrow"
            tools:ignore="ContentDescription"/>

        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

        <ImageButton
            android:id="@+id/btnBackward"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/round_button"
            android:rotation="270"
            android:src="@drawable/arrow"
            tools:ignore="ContentDescription"/>

        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

    </GridLayout>

    <GridLayout
        android:id="@+id/dpadCameraLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:columnCount="3"
        android:rowCount="3"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">



        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

        <ImageButton
            android:id="@+id/btnCamUp"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/round_button"
            android:rotation="90"
            android:src="@drawable/arrow"
            tools:ignore="ContentDescription"/>

        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

        <ImageButton
            android:id="@+id/btnCamLeft"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/round_button"
            android:src="@drawable/arrow"
            tools:ignore="ContentDescription"/>

        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

        <ImageButton
            android:id="@+id/btnCamRight"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/round_button"
            android:rotation="180"
            android:src="@drawable/arrow"
            tools:ignore="ContentDescription"/>

        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

        <ImageButton
            android:id="@+id/btnCamDown"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="@drawable/round_button"
            android:rotation="270"
            android:src="@drawable/arrow"
            tools:ignore="ContentDescription"/>

        <View
            android:layout_width="60dp"
            android:layout_height="60dp" />

    </GridLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
